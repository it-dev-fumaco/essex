# Override these in .env or via docker-compose for Docker deployment.
# Copy relevant values to your .env. docker-compose sets these via environment: block.

# Served behind shared NGINX (see docker/nginx/conf.d/essex-athena-reverse-proxy.conf.example).
APP_URL=http://essex.local
ASSET_URL=http://essex.local
HTTPS=false

# Shared infrastructure
SHARED_NETWORK_NAME=athenaerp-1_athenaerp
SHARED_REDIS_HOST=athenaerp-redis
SHARED_REDIS_PORT=6379
ESSEX_FORWARD_APP_PORT=8000
ESSEX_APP_URL=http://essex.local
ESSEX_ASSET_URL=http://essex.local

# Redis (app container connects to shared redis service)
REDIS_HOST=athenaerp-redis
REDIS_PORT=6379
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
