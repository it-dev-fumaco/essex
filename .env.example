#============================================================================
# Application (config/app.php)
#============================================================================
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Base URL for notice slip approval links in emails (optional). Use internal URL e.g. https://10.0.0.5 so links open on your network.
# NOTICE_SLIP_BASE_URL=https://10.0.0.5

HTTPS=false

#============================================================================
# Logging (config/logging.php)
#============================================================================
LOG_CHANNEL=stack

#============================================================================
# Database (config/database.php)
#============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=secret
DB_SOCKET=
DB_TIMEZONE=+08:00
# Seconds; avoids hanging requests when MySQL is unreachable (Docker / VPN).
DB_CONNECT_TIMEOUT=30

DB_ERP=erp_test_db
DB_KB=knowledgebase

#============================================================================
# Cache, Queue, Session (config/cache.php, queue.php, session.php)
#============================================================================
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

#============================================================================
# Filesystem (config/filesystems.php)
#============================================================================
FILESYSTEM_DRIVER=local

#============================================================================
# Redis (config/database.php redis)
#============================================================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Shared staging Docker infrastructure (athenaerp-1)
SHARED_NETWORK_NAME=athenaerp-1_athenaerp
SHARED_REDIS_HOST=athenaerp-redis
SHARED_REDIS_PORT=6379
# HTTP is served by athenaerp-nginx (FastCGI to essex-app:9000). No Essex nginx container.
# Docker Compose passes APP_URL/ASSET_URL into the container from these same keys in .env.
# Optional legacy aliases (used only if APP_URL / ASSET_URL are unset):
# ESSEX_APP_URL=http://essex.local
# ESSEX_ASSET_URL=http://essex.local

#============================================================================
# Mail (config/mail.php)
#============================================================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=Example

MAIL_RECIPIENT=it@example.com

#============================================================================
# Broadcasting (config/broadcasting.php)
#============================================================================
BROADCAST_DRIVER=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

#============================================================================
# Application-specific
#============================================================================
LINK_KB=http://localhost:8085
BASE_PATH=
AD_USERNAME=
AD_PASSWORD=
